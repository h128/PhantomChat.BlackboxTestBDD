PHANTOMCHAT_HTTP_BASE_URL=https://iping.site
PHANTOMCHAT_WS_URL=wss://iping.site/room
PHANTOMCHAT_VERIFY_TLS=true
PHANTOMCHAT_REQUEST_TIMEOUT_SECONDS=5
PHANTOMCHAT_EVENT_TIMEOUT_SECONDS=5
PHANTOMCHAT_STARTUP_TIMEOUT_SECONDS=30

# Optional: let the test suite boot the system under test as an external process.
# Example:
# PHANTOMCHAT_SERVER_COMMAND=cmake --build out/build/windows-msvc-debug-developer-mode --config Debug --target PhantomServer && .\\out\\build\\windows-msvc-debug-developer-mode\\src\\phantom_server\\Debug\\PhantomServer.exe
# PHANTOMCHAT_SERVER_WORKDIR=C:\\Programming\\My source\\PhantomChat\\src\\phantom_server
